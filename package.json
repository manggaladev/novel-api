{
  "name": "novel-api",
  "version": "3.0.0",
  "description": "REST API for novel platform with authentication, RBAC, chapters, bookmarks, ratings, comments, likes",
  "main": "dist/index.js",
  "author": "manggaladev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/manggaladev/novel-api"
  },
  "bugs": {
    "url": "https://github.com/manggaladev/novel-api/issues"
  },
  "homepage": "https://github.com/manggaladev/novel-api#readme",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "sanitize-html": "^2.14.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.4",
    "@types/sanitize-html": "^2.13.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "keywords": ["novel", "api", "rest", "express", "typescript", "prisma", "jwt", "auth"]
